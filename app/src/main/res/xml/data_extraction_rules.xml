<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include database files in cloud backup -->
        <include domain="database" />
    </cloud-backup>
    
    <device-transfer>
        <!-- Include all app data in device transfer -->
        <include domain="database" />
        <include domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
